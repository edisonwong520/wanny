# ==========================================
# Database Configuration
# ==========================================
DB_NAME=wanny
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ==========================================
# Midea IoT Cloud-to-Cloud API Configuration
# ==========================================
# 从美的 IoT 开发者平台获取的 Client ID
MIDEA_CLIENT_ID=your_midea_client_id_here

# 从美的 IoT 开发者平台获取的 Client Secret
MIDEA_CLIENT_SECRET=your_midea_client_secret_here

# 回调地址 (默认为 https://localhost/callback)
MIDEA_REDIRECT_URI=https://localhost/callback

# 授权码获取后填入此项换取 Token (测试用)
MIDEA_AUTH_CODE=your_auth_code_here

# 获取到的 Access Token (如果持久化保存可填入测试用)
MIDEA_ACCESS_TOKEN=your_access_token_here

# ==========================================
# Large Language Model Configuration (OpenAI Compatible)
# ==========================================
# AI Provider's Base URL (e.g. https://api.openai.com/v1 or local address)
AI_BASE_URL=https://api.deepseek.com/v1

# AI Provider's API Key
AI_API_KEY=sk-your-ai-key-here

# Selected model string (e.g. gpt-4o, gemini-1.5-pro, deepseek-chat)
AI_MODEL=deepseek-chat

# ==========================================
# Google GenAI Settings (Fallback & Secondary)
# ==========================================
# 如果你希望使用原生的 Google Gemini SDK，而非兼容的 OpenAI 接口代理，请填写这组（优先级低于 AI_BASE_URL）：
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# IoT Status Daemon
# ==========================================
# 设置巡检大循环的触发间隔（单位：秒）。建议验证测试时用 30，线上长期稳定环境可设为 120-300。
MONITOR_POLL_INTERVAL=30

# 连续被用户批准多少次后，触发"建议永久授权"的升级提问（默认 3 次）
MONITOR_ELEVATE_THRESHOLD=3

# ==========================================
# Memory Engine (ChromaDB + Daily Review)
# ==========================================
# 向量数据库持久化目录
CHROMA_PERSIST_DIR=./chroma_data

# Embedding 模型（配置了 GEMINI_API_KEY 时生效，默认 text-embedding-004）
# 若未配置 GEMINI_API_KEY，将降级使用 ChromaDB 内置的 all-MiniLM-L6-v2
CHROMA_EMBEDDING_MODEL=text-embedding-004

# 每日复盘引擎的执行时间（24小时制，默认凌晨 3 点）
REVIEW_HOUR=3


