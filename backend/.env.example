# ==========================================
# Database Configuration
# ==========================================
DB_NAME=wanny
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_ENGINE=django.db.backends.mysql

# ==========================================
# Large Language Model Configuration (OpenAI Compatible)
# ==========================================
# AI Provider's Base URL (e.g. https://api.openai.com/v1 or local address)
AI_BASE_URL=https://api.deepseek.com/v1

# AI Provider's API Key
AI_API_KEY=sk-your-ai-key-here

# Selected model string (e.g. gpt-4o, gemini-1.5-pro, deepseek-chat)
AI_MODEL=deepseek-chat

# ==========================================
# Agent Configuration
# ==========================================
# 自定义系统的 System Prompt，用于微调 AI 处理意图时的性格与策略
# 如果留空，将使用 backend/apps/comms/ai.py 中内置的默认 Prompt
AGENT_SYSTEM_PROMPT=

# ==========================================
# Google GenAI Settings (Fallback & Secondary)
# ==========================================
# 如果你希望使用原生的 Google Gemini SDK，而非兼容的 OpenAI 接口代理，请填写这组（优先级低于 AI_BASE_URL）：
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# IoT Status Daemon
# ==========================================
# 设置巡检大循环的触发间隔（单位：秒）。建议验证测试时用 30，线上长期稳定环境可设为 120-300。
MONITOR_POLL_INTERVAL=30

# 连续被用户批准多少次后，触发"建议永久授权"的升级提问（默认 2 次）
MONITOR_ELEVATE_THRESHOLD=2

# 工作线程巡检循环间隔（秒）
WORKER_LOOP_INTERVAL=10

# 设备快照强制全量全量同步间隔（秒），建议保持在 300 以上
DEVICE_SYNC_INTERVAL=300

# ==========================================
# Memory Engine (ChromaDB + Daily Review)
# ==========================================
# 向量数据库持久化目录
CHROMA_PERSIST_DIR=./chroma_data

# Embedding 专用 API Key（Google Gemini），与 AI 推理的 Key 解耦
EMBEDDING_API_KEY=your-google-gemini-api-key-here

# Embedding 模型（配置了 EMBEDDING_API_KEY 时生效，默认 gemini-embedding-2-preview）
# 若未配置 EMBEDDING_API_KEY，将降级使用 ChromaDB 内置的 all-MiniLM-L6-v2
CHROMA_EMBEDDING_MODEL=gemini-embedding-2-preview

# 每日复盘引擎的执行时间（24小时制，默认 0,12 点，支持多选）
REVIEW_HOURS=0,12

# 单次复盘任务支持的时间点（仅作单选时备用，优先级低于 REVIEW_HOURS）
REVIEW_HOUR=

# 复盘任务扫描历史记录的回溯时长（单位：小时，默认 12）
REVIEW_LOOKBACK_HOURS=12
