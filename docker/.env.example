# Docker Compose interpolation values.
# Copy this file to docker/.env before running docker compose.

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=wanny
MYSQL_USER=wanny
MYSQL_PASSWORD=change-this-app-password

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave empty when frontend and backend share the same nginx origin.
VITE_API_BASE_URL=
